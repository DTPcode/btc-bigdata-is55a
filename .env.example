# =====================================================================
# COPY FILE NÀY THÀNH ".env" (bỏ .example) RỒI ĐIỀN GIÁ TRỊ THẬT VÀO
# KHÔNG BAO GIỜ commit file ".env" hoặc "credentials.json" lên Git
# =====================================================================

# ── Google Cloud / BigQuery ────────────────────────────────
GCP_PROJECT_ID=your-project-id
BQ_DATASET_ID=btc_bigdata
BQ_LOCATION=US
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# ── Binance ──────────────────────────────────────────────────
# Để trống vẫn lấy được public market data (không cần đăng nhập)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Cấu hình pipeline ────────────────────────────────────────
SYMBOL=BTCUSDT
INTERVAL=1h
HISTORY_START_DATE=2020-01-01
INCREMENTAL_LOOKBACK=200

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
